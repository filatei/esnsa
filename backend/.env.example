# ─── Server ───────────────────────────────────────────────
PORT=3031
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=esnsa_db
DB_USER=esnsa_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_LONG_RANDOM_STRING_MIN_64_CHARS
JWT_EXPIRES_IN=8h

# ─── Anthropic ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-PASTE_YOUR_KEY_HERE

# ─── File uploads ─────────────────────────────────────────
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=10mb
